# Copy this file to .env at the workspace root and fill in real values.
# .env is gitignored — never commit secrets.

# ─── Database ─────────────────────────────────────────────────────────
# Local development (matches docker-compose.yml):
DATABASE_URL=postgres://kantr:kantr_dev@localhost:5432/kantr_dev

# Production targets GCP Jakarta (self-hosted Postgres 16) per ADR-002.
# Format: postgres://user:password@host:port/database?sslmode=require

# ─── Anthropic API (used by apps/roadmap /api/chat) ────────────────────
# Set in Vercel dashboard for the roadmap app, do not commit.
# ANTHROPIC_API_KEY=sk-ant-...
