{
  "name": "kantr",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "dev:roadmap":   "turbo dev --filter=@kantr/roadmap",
    "build:roadmap": "turbo build --filter=@kantr/roadmap",
    "dev:marketing":   "turbo dev --filter=@kantr/marketing",
    "build:marketing": "turbo build --filter=@kantr/marketing",
    "dev:docs":   "turbo dev --filter=@kantr/docs",
    "build:docs": "turbo build --filter=@kantr/docs"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@10.33.0"
}
